10.
    # Assume:
    # Clubs: list[str]
    # Statistics: list[list[int]] #assume [[wins, draws, losses], ...]
    # Points: list[int]

    from typing import Final, Literal

    MAX_MATCHES: Final = 22
    ZERO: Literal[0] = 0
    WIN_POINTS: Final = 12
    DRAW_POINTS: Final = 5
    LOSS_POINTS: Final = 0


    
    def get_number_in_range(low: int, high: int) -> int:
        """takes input from stdin until low <= int(input()) <= high. Returns the first such valid value."""
        
        # Initialize value to an invalid state
        value: int | None = None
        
        #take input until value becomes valid
        while value == None or not(low <= value <= high):
            try:
                value = int(input(f"Please enter a number between {low} and {high} for the number of matches per team"))
            except ValueError:
                print("Please input a number!")
        return value
    
    #get number of matches

    Matches = get_number_in_range(ZERO, MAX_MATCHES)

    # Input teams until finished
    while True:
        club = input("Please enter the name of the club or just press enter (leaving the input empty or with only whitespace) to exit")

        if len(club.strip()) == ZERO:
            break #if there is only whitespace or there is no input at all, break

        Clubs.append(club)

        # we cannot have negative won/draw/lost matches, and we know immediately the total will be too high if the user inputs any one of the value as higher than Matches, so we use get_number_in_range again
        won = get_number_in_range(ZERO, Matches)
        draw = get_number_in_range(ZERO, Matches)
        lost = get_number_in_range(ZERO, Matches)

        #while the total does not match the number of matches played, ask the user to input again

        while won + draw + lost != Matches:
            won = get_number_in_range(ZERO, Matches)
            draw = get_number_in_range(ZERO, Matches)
            lost = get_number_in_range(ZERO, Matches)
        
        Statistics.append([won, draw, lost])
        Points.append(won * WIN_POINTS + draw * DRAW_POINTS + lost * LOSS_POINTS)
    victors: list[tuple[str, int, int]] = [] # (name, number of wins, points awarded)
    
    max_points = -1 #initialize to impossibly low value

    #find club(s) with max points by looping through array
    for points, club, stats in zip(Points, Clubs, Statistics):

        persistent_tuple = (club, stats[0], points) # club name, wins, points awarded
        if points > max_points:
            max_points = points
            victors = [persistent_tuple]
        elif points == max_points:
            victors.append(persistent_tuple)
    
    print(f"Total points of winning club(s): {victors[0][2]}") #all points are the same, so no point outputting more than once
    print("Winning club(s): ")

    print(",\n".join(f"{club} with {wins} wins" for club, wins, _ in victors)) #output names and wins of winning clubs separated by a comma and a newline