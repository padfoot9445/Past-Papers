    DECLARE Value : INTEGER
    INPUT Value
    MATCH ON Value
        CASE OF 1
            OUTPUT 1
        CASE OF 2
            OUTPUT 2
        CASE OF 3
            OUTPUT 3
        CASE OF 4
            OUTPUT 4
        OTHERWISE
            OUTPUT "ERROR"
    ENDMATCH
